---
import { Image } from "astro:assets";
import heroPanelTecho from "../assets/proteccion-contra-la-energia-termica-del-sol.webp";
---

<section class="hero">
  <div class="hero__wrapper container">
    <div class="hero__left reveal">
      <div class="hero__eyebrow">Paneles arquitectónicos industriales</div>

      <h1 class="hero__title">
        Estructura<br />
        que <span>protege.</span><br />
        Diseño que<br />
        perdura.
      </h1>

      <p class="hero__sub">
        Soluciones de panel de techo con aislamiento térmico, resistencia
        estructural e instalación rápida para proyectos industriales y
        comerciales en México.
      </p>

      <div class="hero__actions">
        <a href="#soluciones" class="hero__btn hero__btn--primary">
          Ver especificaciones
        </a>

        <a href="/contacto/" class="hero__btn hero__btn--ghost">
          Solicitar cotización
        </a>
      </div>
    </div>

    <div class="hero__right reveal">
      <div class="hero__grid" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
        <span></span>
      </div>

      <div class="hero__visual">
        <div class="hero__panel">
          <div class="hero__panel-top"></div>

          <div class="hero__panel-face">
            <div class="hero__panel-copy">
              <span class="hero__panel-label">Panel de techo</span>
              <strong class="hero__panel-value">Alta eficiencia</strong>
            </div>
          </div>

          <div class="hero__panel-side"></div>
        </div>
      </div>

      <div class="hero__image-card">
        <Image
          src={heroPanelTecho}
          alt="Panel de techo industrial para naves y edificios en México"
          width={700}
          height={420}
          loading="eager"
          class="hero__img"
        />
      </div>

      <div class="hero__stats">
        <div class="hero__stat">
          <div class="hero__stat-number">+40</div>
          <div class="hero__stat-label">Años en el mercado</div>
        </div>

        <div class="hero__stat">
          <div class="hero__stat-number">4</div>
          <div class="hero__stat-label">Líneas de producto</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden; /* ← YA LO TIENES */
    background: linear-gradient(90deg, #05080c 0%, #0a0f15 55%, #0c1118 100%);
    min-height: calc(70vh - 72px);
    display: flex;
    align-items: center;
    padding: 0;
  }

  .hero__wrapper {
    display: grid;
    grid-template-columns: minmax(320px, 0.95fr) minmax(420px, 1.05fr);
    gap: 3rem;
    align-items: center;
    min-height: calc(70vh - 72px);
    padding-top: 4rem;
    padding-bottom: 4rem;
    max-width: var(--container-width); /* ← AGREGADO */
    overflow: hidden; /* ← AGREGADO */
  }

  .hero__left {
    max-width: 520px;
    padding-right: 1rem;
  }

  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.75rem;
    font-family: var(--font-heading);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .hero__eyebrow::before {
    content: "";
    width: 1.5rem;
    height: 1px;
    background: currentColor;
  }

  .hero__title {
    margin: 0 0 1.5rem;
    font-family: var(--font-heading);
    font-size: clamp(4.4rem, 8vw, 6.9rem);
    font-weight: 900;
    line-height: 0.88;
    letter-spacing: -0.05em;
    text-transform: uppercase;
    color: #f3f1ec;
    letter-spacing: -0.01em;
  }

  .hero__title span {
    color: var(--color-accent);
  }

  .hero__sub {
    max-width: 27rem;
    margin: 0 0 2.2rem;
    font-size: 1rem;
    line-height: 1.85;
    color: rgba(255, 255, 255, 1);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
  }

  .hero__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0.9rem 1.8rem;
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    transition:
      background-color 0.25s ease,
      color 0.25s ease,
      border-color 0.25s ease,
      transform 0.25s ease;
  }

  .hero__btn--primary {
    background: var(--color-accent);
    color: #ffffff;
  }

  .hero__btn--primary:hover {
    background: var(--color-accent-hover);
    transform: translateY(-1px);
  }

  .hero__btn--ghost {
    border: 1px solid #313845;
    color: #8a939f;
    background: transparent;
  }

  .hero__btn--ghost:hover {
    border-color: #69717c;
    color: #ffffff;
    transform: translateY(-1px);
  }

  .hero__right {
    position: relative;
    min-height: 680px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden; /* ← MANTENER */
    max-width: 100%; /* ← AGREGADO */
  }

  .hero__grid {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 1px;
    opacity: 0.26;
  }

  .hero__grid span {
    background: linear-gradient(180deg, #0d131a, #0a0f15);
    border: 1px solid rgba(20, 25, 32, 0.4);
  }

  .hero__visual {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
  pointer-events: none;
}

  .hero__panel {
    position: relative;
    width: min(360px, 48%);
    height: 240px;
  }

  .hero__panel-top {
    position: absolute;
    left: 38px;
    right: 0;
    height: 86px;
    background:
      linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.03) 0 12%,
        transparent 12% 22%,
        rgba(255, 255, 255, 0.03) 22% 34%,
        transparent 34% 44%,
        rgba(255, 255, 255, 0.03) 44% 56%,
        transparent 56% 66%,
        rgba(255, 255, 255, 0.03) 66% 78%,
        transparent 78% 88%,
        rgba(255, 255, 255, 0.03) 88% 100%
      ),
      linear-gradient(180deg, #465169, #313a4d);
    clip-path: polygon(22px 0, 100% 0, 100% 100%, 0 100%);
  }

  .hero__panel-face {
    position: absolute;
    left: 0;
    right: 38px;
    bottom: 0;
    height: 140px;
    background: linear-gradient(90deg, #232a37, #1c2330);
    display: flex;
    align-items: flex-end;
    padding: 1rem;
  }

  .hero__panel-side {
    position: absolute;
    top: 0;
    right: 0;
    width: 38px;
    height: 100%;
    background: linear-gradient(180deg, #1a2232, #091026);
  }

  .hero__panel-copy {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .hero__panel-label {
    font-family: var(--font-heading);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #616c7a;
  }

  .hero__panel-value {
    font-family: var(--font-heading);
    font-size: 1.8rem;
    font-weight: 900;
    line-height: 1;
    color: var(--color-accent);
    text-transform: uppercase;
  }

  .hero__image-card {
    position: absolute;
    right: 0; /* ← CAMBIADO de -5% */
    top: 50%;
    transform: translateY(-70%);
    width: min(460px, 65%); /* ← CAMBIADO de 70% a 65% */
    opacity: 0.8;
    z-index: 1;
    overflow: hidden;
    mix-blend-mode: screen;
    max-width: 100%; /* ← AGREGADO */
  }

  .hero__img {
    width: 100%;
    height: 420px;
    object-fit: cover;
  }

  .hero__stats {
  position: absolute;
  right: 1.5rem;
  bottom: 2rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
  z-index: 3;
  text-align: right;
}

  .hero__stat-number {
    font-family: var(--font-heading);
    font-size: 2.15rem;
    font-weight: 900;
    line-height: 1;
    color: #ffffff;
  }

  .hero__stat-label {
    margin-top: 0.2rem;
    font-family: var(--font-heading);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #4f5967;
  }

  @media (max-width: 1200px) {
    .hero__title {
      font-size: clamp(3.8rem, 8vw, 5.8rem);
    }

    .hero__right {
      min-height: 620px;
      overflow: hidden; /* ← MANTENER EN TODAS LAS MEDIA QUERIES */
    }

    .hero__image-card {
      right: 0;
      width: min(380px, 55%);
    }
  }

  @media (max-width: 1024px) {
    .hero {
      min-height: auto;
    }

    .hero__wrapper {
      grid-template-columns: 1fr;
      gap: 2.75rem;
      min-height: auto;
      padding-top: 4rem;
      padding-bottom: 4rem;
      overflow: hidden; /* ← MANTENER */
    }

    .hero__left {
      max-width: 100%;
      padding-right: 0;
    }

    .hero__sub {
      max-width: 40rem;
    }

    .hero__right {
      min-height: 520px;
      overflow: hidden; /* ← MANTENER */
    }

    .hero__image-card {
      right: 0;
      width: min(300px, 38%);
    }
  }

  @media (max-width: 768px) {
  .hero__right {
    min-height: auto;
    height: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    padding-bottom: 1.5rem;
  }

  .hero__visual {
    position: relative;  /* ← overrides el absolute solo en móvil */
    inset: unset;
    width: 100%;
    height: 220px;
  }

  .hero__stats {
    position: relative;  /* ← overrides el absolute solo en móvil */
    inset: unset;
    flex-direction: row;
    justify-content: center;
    gap: 3rem;
    text-align: center;
    right: unset;
    bottom: unset;
  }

  .hero__stat-label {
    text-align: center;
  }

  .hero__image-card {
    display: none;
  }

  .hero__panel {
    width: min(290px, 72%);
    height: 200px;
  }

  .hero__panel-top {
    height: 70px;
    left: 28px;
  }

  .hero__panel-face {
    right: 28px;
    height: 120px;
  }

  .hero__panel-side {
    width: 28px;
  }

  .hero__panel-value {
    font-size: 1.45rem;
  }
}

@media (max-width: 560px) {
  .hero__eyebrow {
    font-size: 0.66rem;
    letter-spacing: 0.18em;
  }

  .hero__panel {
    width: min(260px, 82%);
    height: 180px;
  }
}
</style>
