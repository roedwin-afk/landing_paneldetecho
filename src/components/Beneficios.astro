---
import { Thermometer, Zap, Building2 } from "lucide-astro";

const beneficios = [
  {
    icono: Thermometer,
    titulo: "Aislamiento térmico eficiente",
    texto:
      "Reduce la ganancia térmica en cubierta y ayuda a mantener un mejor comportamiento interior en naves, bodegas y edificios expuestos al sol."
  },
  {
    icono: Zap,
    titulo: "Instalación más rápida",
    texto:
      "Su formato prefabricado y sistema de ensamble facilita un montaje más ágil, con menos procesos en sitio y mayor eficiencia durante la instalación."
  },
  {
    icono: Building2,
    titulo: "Resistencia industrial",
    texto:
      "Pensado para cubiertas que requieren desempeño estructural, protección frente a la intemperie y durabilidad en aplicaciones industriales exigentes."
  }
];
---

<section class="beneficios section" id="beneficios">
  <div class="beneficios__container container">
    <div class="beneficios__header reveal">
      <div class="section-label">Beneficios clave</div>
      <h2 class="section-title beneficios__title">
        ¿Por qué elegir panel sándwich<br />
        para tu techo?
      </h2>
      <p class="section-text beneficios__intro">
        Más que una cubierta, es un sistema que aporta aislamiento, velocidad de
        instalación y mejor desempeño para proyectos industriales y comerciales.
      </p>
    </div>

    <div class="beneficios__grid">
      {beneficios.map(({ icono: Icono, titulo, texto }, index) => (
        <article class="beneficios__card reveal">
          <div class="beneficios__top">
            <span class="beneficios__number">
              {String(index + 1).padStart(2, "0")}
            </span>
            <Icono class="beneficios__icon" size={24} stroke-width={1.5} />
          </div>

          <h3 class="beneficios__name">{titulo}</h3>
          <p class="beneficios__text">{texto}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .beneficios {
    background: var(--color-primary-soft);
    position: relative;
    overflow: hidden;
  }

  /* Opcional: Agregar un gradient sutil */
  .beneficios::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at 30% 20%,
      rgba(212, 80, 10, 0.03) 0%,
      transparent 50%
    );
    pointer-events: none;
  }

  .beneficios__container {
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
    position: relative;
    z-index: 1;
  }

  .beneficios__header {
    max-width: 860px;
  }

  .beneficios__title {
    color: var(--color-white);
    margin-bottom: 1.25rem;
  }

  .beneficios__intro {
    max-width: 680px;
    color: rgba(255, 255, 255, 0.7);
    font-size: 1.05rem;
  }

  .beneficios__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .beneficios__card {
    background: linear-gradient(180deg, #1a1d22 0%, #111419 100%);
    padding: 2rem 1.75rem;
    min-height: 280px;
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-md);
    border: 1px solid rgba(255, 255, 255, 0.06);
    transition:
      transform var(--transition-base),
      background-color var(--transition-base),
      border-color var(--transition-base);
  }

  .beneficios__card:hover {
    transform: translateY(-6px);
    background: linear-gradient(180deg, #20242b 0%, #151920 100%);
    border-color: rgba(212, 80, 10, 0.2);
  }

  .beneficios__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }

  .beneficios__number {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.3);
  }

  .beneficios__icon {
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .beneficios__name {
    margin-bottom: 1rem;
    font-family: var(--font-heading);
    font-size: clamp(1.35rem, 2vw, 1.75rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--color-white);
  }

  .beneficios__text {
    color: rgba(255, 255, 255, 0.68);
    font-size: 0.96rem;
    line-height: 1.7;
  }

  @media (max-width: 1024px) {
    .beneficios__grid {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .beneficios__card {
      min-height: auto;
      padding: 1.75rem 1.5rem;
    }
  }

  @media (max-width: 768px) {
    .beneficios__container {
      gap: 2.5rem;
    }

    .beneficios__intro {
      font-size: 1rem;
    }

    .beneficios__card {
      padding: 1.5rem 1.25rem;
    }

    .beneficios__name {
      line-height: 1.05;
      margin-bottom: 0.85rem;
    }

    .beneficios__text {
      font-size: 0.94rem;
    }
  }
</style>