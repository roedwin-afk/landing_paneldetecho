---
const beneficios = [
  {
    icono: "🌡️",
    titulo: "Aislamiento térmico superior",
    texto: "Reduce hasta un 40% el consumo energético en climatización de naves y edificios industriales."
  },
  {
    icono: "⚡",
    titulo: "Instalación rápida",
    texto: "Sistema machihembrado que reduce los tiempos de obra hasta un 60% comparado con métodos tradicionales."
  },
  {
    icono: "🏗️",
    titulo: "Alta resistencia estructural",
    texto: "Soporta cargas de viento y nieve, ideal para naves industriales, bodegas y edificios comerciales."
  }
];
---

<section class="beneficios reveal" id="soluciones">
  <div class="beneficios__wrapper">
    <h2 class="beneficios__titulo">¿Por qué elegir panel sándwich para tu techo?</h2>
    <div class="beneficios__grid">
      {beneficios.map((b) => (
        <div class="beneficios__item">
          <span class="beneficios__icono">{b.icono}</span>
          <h3 class="beneficios__nombre">{b.titulo}</h3>
          <p class="beneficios__texto">{b.texto}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .beneficios {
    padding: 5rem 2rem;
    background-color: #F5F5F0;
  }

  .beneficios__wrapper {
    max-width: 1200px;
    margin: 0 auto;
  }

  .beneficios__titulo {
    text-align: center;
    color: var(--color-primary);
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 3rem;
  }

  .beneficios__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .beneficios__item {
    background: var(--color-white);
    border-radius: 8px;
    padding: 2rem;
    text-align: center;
    border-top: 4px solid var(--color-accent);
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  }

  .beneficios__icono {
    font-size: 2.5rem;
    display: block;
    margin-bottom: 1rem;
  }

  .beneficios__nombre {
    color: var(--color-primary);
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .beneficios__texto {
    color: #555;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: all 0.6s ease;
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 768px) {
    .beneficios__grid {
      grid-template-columns: 1fr;
    }
  }
</style>