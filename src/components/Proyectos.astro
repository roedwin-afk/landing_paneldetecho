---
import { Image } from "astro:assets";

import proyecto1 from "../assets/proyecto-techo-nave-industrial.webp";
import proyecto2 from "../assets/proyecto-techo-bodega.jpg";
import proyecto3 from "../assets/proyecto-techo-comercial.webp";
---

<section class="proyectos reveal">
  <div class="proyectos__wrapper">
    <h2 class="proyectos__titulo">Proyectos realizados</h2>
    <p class="proyectos__sub">Instalaciones reales de panel de techo en El Salvador y Centroamérica</p>
    <div class="proyectos__grid">
      <div class="proyectos__card reveal">
        <Image
          src={proyecto1}
          alt="Proyecto techo nave industrial"
          width={400}
          height={300}
          class="proyectos__img"
          format="webp"
          quality={80}
        />
        <div class="proyectos__info">
          <p>Techo panel sándwich para nave industrial de manufactura.</p>
        </div>
      </div>
      <div class="proyectos__card reveal">
        <Image
          src={proyecto2}
          alt="Proyecto techo bodega"
          width={400}
          height={300}
          class="proyectos__img"
          format="webp"
          quality={80}
        />
        <div class="proyectos__info">
          <p>Instalación de techo aislante para bodega de distribución.</p>
        </div>
      </div>
      <div class="proyectos__card reveal">
        <Image
          src={proyecto3}
          alt="Proyecto techo comercial"
          width={400}
          height={300}
          class="proyectos__img"
          format="webp"
          quality={80}
        />
        <div class="proyectos__info">
          <p>Techo panel para edificio comercial con aislamiento acústico.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .proyectos {
    padding: 5rem 2rem;
    background-color: var(--color-white);
  }

  .proyectos__wrapper {
    max-width: 1200px;
    margin: 0 auto;
  }

  .proyectos__titulo {
    text-align: center;
    color: var(--color-primary);
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .proyectos__sub {
    text-align: center;
    color: #777;
    font-size: 1rem;
    margin-bottom: 3rem;
  }

  .proyectos__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .proyectos__card {
    background: #F5F5F0;
    border-radius: 8px;
    overflow: hidden;
    transition: transform 0.3s ease;
  }

  .proyectos__card:hover {
    transform: translateY(-5px);
  }

  .proyectos__img {
    width: 100%;
    height: 220px;
    object-fit: cover;
  }

  .proyectos__info {
    padding: 1rem 1.25rem;
    font-size: 0.9rem;
    color: #555;
    line-height: 1.6;
  }

  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: all 0.6s ease;
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 768px) {
    .proyectos__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 480px) {
    .proyectos__grid {
      grid-template-columns: 1fr;
    }

    .proyectos__img {
      height: 200px;
    }
  }
</style>