---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";

// const response = await fetch(`${import.meta.env.WORDPRESS_API_URL}/posts?_embed&per_page=100`);
// const posts = await response.json();

export async function getStaticPaths() {
  const POSTS_PER_PAGE = 6;
  const allPosts = [
    {
      id: 1,
      date: "2026-04-10T12:00:00",
      slug: "instalacion-cuartos-frios",
      title: { rendered: "Instalación de Cuartos Fríos: Guía Completa" },
      excerpt: {
        rendered:
          "Aprende los aspectos clave para instalar un cuarto frío eficiente y duradero.",
      },
      _embedded: {
        "wp:featuredmedia": [
          {
            source_url: "https://via.placeholder.com/800x400?text=Cuarto+Frio",
          },
        ],
      },
    },
    {
      id: 2,
      date: "2026-04-08T10:30:00",
      slug: "paneles-aislantes-beneficios",
      title: { rendered: "Beneficios de los Paneles Aislantes" },
      excerpt: {
        rendered:
          "Descubre por qué los paneles aislantes son clave en la refrigeración.",
      },
      _embedded: {
        "wp:featuredmedia": [
          { source_url: "https://via.placeholder.com/800x400?text=Paneles" },
        ],
      },
    },
    {
      id: 3,
      date: "2026-04-05T09:00:00",
      slug: "mantenimiento-cuartos-frios",
      title: { rendered: "Mantenimiento de Cuartos Fríos" },
      excerpt: {
        rendered:
          "Consejos prácticos para alargar la vida útil de tu cuarto frío.",
      },
      _embedded: {
        "wp:featuredmedia": [
          {
            source_url:
              "https://via.placeholder.com/800x400?text=Mantenimiento",
          },
        ],
      },
    },
  ];

  const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);

  return Array.from({ length: totalPages }, (_, i) => ({
    params: { page: String(i + 1) },
    props: {
      posts: allPosts.slice(i * POSTS_PER_PAGE, (i + 1) * POSTS_PER_PAGE),
      currentPage: i + 1,
      totalPages,
    },
  }));
}

const { posts, currentPage, totalPages } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<Layout
  title="Blog | Panel de Techo"
  description="Artículos sobre panel sándwich para techo, aislamiento industrial, cubiertas, instalación y aplicaciones en proyectos industriales y comerciales."
>
  <Navbar />

  <main class="blog-page">
    <section class="blog-hero">
      <div class="blog-hero__container container">
        <div class="blog-hero__content reveal">
          <div class="section-label">Contenido técnico</div>
          <h1 class="blog-hero__title">
            Blog sobre paneles,<br />
            cubiertas y <span>aislamiento.</span>
          </h1>
          <p class="blog-hero__text">
            Información útil sobre panel sándwich para techo, aplicaciones,
            instalación, eficiencia térmica y criterios de especificación para
            proyectos industriales y comerciales en El Salvador y Centroamérica.
          </p>
        </div>
      </div>
    </section>

    <section class="blog-list section">
      <div class="blog-list__container container">
        <div class="blog-list__top reveal">
          <p class="blog-list__count">
            {posts.length} artículo{posts.length !== 1 ? "s" : ""}
          </p>
        </div>

        <div class="blog-grid">
          {
            posts.map((post: any, index: number) => (
              <article class="blog-card reveal">
                <a href={`${base}blog/${post.slug}/`} class="blog-card__media">
                  {post._embedded?.["wp:featuredmedia"]?.[0]?.source_url && (
                    <img
                      src={post._embedded["wp:featuredmedia"][0].source_url}
                      alt={post.title.rendered}
                      class="blog-card__image"
                      loading={index < 3 ? "eager" : "lazy"}
                    />
                  )}
                  <span class="blog-card__number">
                    {String(index + 1 + (currentPage - 1) * 6).padStart(2, "0")}
                  </span>
                </a>

                <div class="blog-card__content">
                  <p class="blog-card__date">
                    {new Date(post.date).toLocaleDateString("es-SV", {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                    })}
                  </p>

                  <h2 class="blog-card__title">
                    <a
                      href={`${base}blog/${post.slug}/`}
                      set:html={post.title.rendered}
                    />
                  </h2>

                  <div
                    class="blog-card__description"
                    set:html={post.excerpt.rendered}
                  />

                  <a
                    href={`${base}blog/${post.slug}/`}
                    class="blog-card__link"
                  >
                    Leer artículo
                  </a>
                </div>
              </article>
            ))
          }
        </div>

        {
          totalPages > 1 && (
            <nav class="blog-pagination reveal" aria-label="Paginación del blog">
              <div class="blog-pagination__inner">
                {Array.from({ length: totalPages }, (_, i) => i + 1).map(
                  (page) => (
                    <a
                      href={
                        page === 1
                          ? `${base}blog/`
                          : `${base}blog/page/${page}/`
                      }
                      class:list={[
                        "blog-pagination__link",
                        page === currentPage && "is-active",
                      ]}
                    >
                      {String(page).padStart(2, "0")}
                    </a>
                  ),
                )}
              </div>
            </nav>
          )
        }
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .blog-page {
    background: var(--color-bg);
  }

  .blog-hero {
    background: var(--color-secondary);
    padding-block: 4.5rem 3.5rem;
    position: relative;
    overflow: hidden;
  }

  .blog-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(135deg, rgba(255,255,255,0.02), transparent 40%),
      linear-gradient(180deg, rgba(255,255,255,0.02), transparent);
    pointer-events: none;
  }

  .blog-hero__container {
    position: relative;
    z-index: 1;
  }

  .blog-hero__content {
    max-width: 860px;
  }

  .blog-hero__title {
    margin-bottom: 1.25rem;
    font-family: var(--font-heading);
    font-size: clamp(2.8rem, 6vw, 5.2rem);
    font-weight: 900;
    line-height: 0.92;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    color: var(--color-white);
  }

  .blog-hero__title span {
    color: var(--color-accent);
  }

  .blog-hero__text {
    max-width: 42rem;
    color: rgba(255, 255, 255, 0.72);
    font-size: 1rem;
    line-height: 1.8;
  }

  .blog-list__container {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .blog-list__top {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .blog-list__count {
    font-family: var(--font-heading);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .blog-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    overflow: hidden;
    transition:
      transform var(--transition-base),
      border-color var(--transition-base),
      box-shadow var(--transition-base);
  }

  .blog-card:hover {
    transform: translateY(-6px);
    border-color: rgba(212, 80, 10, 0.25);
    box-shadow: var(--shadow-soft);
  }

  .blog-card__media {
    position: relative;
    display: block;
    overflow: hidden;
    background: #ece8df;
  }

  .blog-card__media::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(14, 16, 18, 0.03) 0%,
      rgba(14, 16, 18, 0.18) 100%
    );
    pointer-events: none;
  }

  .blog-card__image {
    width: 100%;
    height: 240px;
    object-fit: cover;
    transition: transform 0.45s ease;
  }

  .blog-card:hover .blog-card__image {
    transform: scale(1.03);
  }

  .blog-card__number {
    position: absolute;
    top: 1rem;
    left: 1rem;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 46px;
    min-height: 46px;
    padding: 0.45rem 0.7rem;
    background: rgba(14, 16, 18, 0.9);
    color: var(--color-white);
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .blog-card__content {
    padding: 1.35rem;
  }

  .blog-card__date {
    margin-bottom: 0.7rem;
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .blog-card__title {
    margin-bottom: 0.8rem;
    font-family: var(--font-heading);
    font-size: clamp(1.25rem, 2vw, 1.7rem);
    font-weight: 800;
    line-height: 0.97;
    letter-spacing: -0.02em;
    text-transform: uppercase;
  }

  .blog-card__title a {
    color: var(--color-primary);
    transition: color var(--transition-base);
  }

  .blog-card__title a:hover {
    color: var(--color-accent);
  }

  .blog-card__description {
    margin-bottom: 1rem;
    color: var(--color-text-soft);
    font-size: 0.95rem;
    line-height: 1.75;
  }

  .blog-card__description :global(p) {
    margin: 0;
  }

  .blog-card__link {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-heading);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    transition:
      color var(--transition-base),
      transform var(--transition-base);
  }

  .blog-card__link:hover {
    transform: translateX(3px);
  }

  .blog-pagination__inner {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .blog-pagination__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 46px;
    min-height: 46px;
    padding: 0.6rem 0.8rem;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text-soft);
    font-family: var(--font-heading);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition:
      border-color var(--transition-base),
      color var(--transition-base),
      background-color var(--transition-base);
  }

  .blog-pagination__link:hover {
    border-color: rgba(212, 80, 10, 0.28);
    color: var(--color-accent);
  }

  .blog-pagination__link.is-active {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: var(--color-white);
  }

  @media (max-width: 1024px) {
    .blog-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 768px) {
    .blog-hero {
      padding-block: 3.5rem 2.75rem;
    }

    .blog-hero__text {
      font-size: 0.97rem;
      line-height: 1.75;
    }

    .blog-card__image {
      height: 220px;
    }
  }

  @media (max-width: 640px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }

    .blog-card__content {
      padding: 1.15rem;
    }

    .blog-card__image {
      height: 210px;
    }
  }
</style>