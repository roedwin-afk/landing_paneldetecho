---
import {
  Thermometer,
  Volume2,
  Zap,
  ShieldCheck,
  Layers
} from "lucide-astro";

const specs = [
  { icon: Thermometer, text: "Aislamiento térmico eficiente" },
  { icon: Volume2, text: "Reducción acústica industrial" },
  { icon: Zap, text: "Instalación rápida en obra" },
  { icon: ShieldCheck, text: "Alta resistencia estructural" },
  { icon: Layers, text: "Acabado arquitectónico premium" }
];

const specsLoop = [...specs, ...specs, ...specs, ...specs];
---

<div class="spec-band">
  <div class="spec-band__track">
    {specsLoop.map(({ icon: Icon, text }) => (
      <div class="spec-item">
        <Icon class="spec-icon" size={18} stroke-width={1.5} />
        <span class="spec-text">{text}</span>
      </div>
    ))}
  </div>
</div>

<style>
  .spec-band {
    width: 100%;
    background: var(--color-accent);
    overflow: hidden;
  }

  .spec-band__track {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    align-items: center;
    gap: 4rem;
    padding: 1rem 0;
    width: max-content;
    animation: marquee 36s linear infinite;
  }

  .spec-band__track:hover {
    animation-play-state: paused;
  }

  /* Con 4 copias, -25% = exactamente 1 copia completa */
  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-25%); }
  }

  .spec-item {
    display: flex;
    flex-direction: row;
    flex-shrink: 0;
    align-items: center;
    gap: 0.65rem;
    white-space: nowrap;
  }

  .spec-icon {
    color: rgba(255, 255, 255, 0.9);
    flex-shrink: 0;
  }

  .spec-text {
    font-family: var(--font-heading);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-white);
  }

  @media (max-width: 768px) {
    .spec-band__track {
      gap: 3rem;
      animation-duration: 24s;
    }

    .spec-text {
      font-size: 0.7rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .spec-band__track {
      animation: none;
      overflow-x: auto;
      width: 100%;
      padding: 1rem var(--container-padding, 1.5rem);
    }
  }
</style>