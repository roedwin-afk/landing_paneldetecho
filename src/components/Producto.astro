---
import { Image } from "astro:assets";
import {
  Check,
  Thermometer,
  ShieldCheck,
  Wind,
  Layers3,
  Droplets,
} from "lucide-astro";
import panelTecho from "../assets/como-instalar-panel-sandwich-madera.webp";
import panelTeja from "../assets/panel_teja.webp";
import panelCamara from "../assets/panel_camara_congelacion.webp";
import panelLanaRoca from "../assets/panel_lana_roca.webp";
import panelFachada from "../assets/panel_fachada.webp";

const ventajas = [
  "Aislamiento térmico eficiente para cubiertas expuestas a alta radiación solar.",
  "Juntas diseñadas para mejorar la estanqueidad y reducir filtraciones de aire y humedad.",
  "Sistema prefabricado que acelera la instalación y reduce tiempos en obra.",
  "Buena respuesta frente a intemperie, viento y exigencia de uso industrial.",
  "Disponible en distintos perfiles, espesores y acabados según el proyecto.",
  "Solución integral para naves, bodegas, centros logísticos y edificios comerciales.",
];

const datos = [
  { icon: Thermometer, label: "Desempeño",  value: "Aislamiento térmico"    },
  { icon: Droplets,    label: "Protección", value: "Barrera ante humedad"    },
  { icon: Wind,        label: "Cubierta",   value: "Uso industrial exterior" },
  { icon: Layers3,     label: "Sistema",    value: "Panel prefabricado"      },
  { icon: ShieldCheck, label: "Proyecto",   value: "Durabilidad y control"   },
];

const galeria = [
  { src: panelTecho,    alt: "Panel sándwich para techo industrial" },
  { src: panelTeja,     alt: "Panel teja para techo"                },
  { src: panelCamara,   alt: "Panel para cámara de congelación"     },
  { src: panelLanaRoca, alt: "Panel con núcleo de lana de roca"     },
  { src: panelFachada,  alt: "Panel para fachada"                   },
];
---

<section class="producto section reveal" id="soluciones">
  <div class="producto__container container">

    <!-- Encabezado -->
    <div class="producto__header">
      <div class="section-label">Sistema de cubierta</div>
      <h2 class="section-title producto__title">
        Panel sándwich para techo.<br />
        Aislamiento, rapidez y protección para obra industrial.
      </h2>
      <p class="section-text producto__intro">
        El panel de techo es una solución constructiva prefabricada para
        cubiertas que combina aislamiento, protección frente a la intemperie y
        una instalación más ágil en obra. Está pensado para proyectos que
        necesitan controlar la temperatura interior, mejorar el desempeño de la
        envolvente y mantener una imagen técnica y profesional en la cubierta.
      </p>
    </div>

    <!-- FILA SUPERIOR: galería (izq) + título/desc/botones (der) -->
    <div class="producto__grid">

      <!-- Galería -->
      <div class="producto__media">
        <div class="producto__image-wrap">
          <img
            id="galeria-main"
            src={galeria[0].src.src}
            alt={galeria[0].alt}
            width={760}
            height={560}
            class="producto__img"
            loading="eager"
          />
          <div class="producto__floating-card">
            <span class="producto__floating-label">Aplicación principal</span>
            <strong class="producto__floating-value">Cubiertas industriales</strong>
          </div>
        </div>

        <div class="producto__thumbs">
          {galeria.map((img, i) => (
            <button
              class={`producto__thumb-btn${i === 0 ? " active" : ""}`}
              data-src={img.src.src}
              data-alt={img.alt}
              aria-label={img.alt}
              type="button"
            >
              <Image
                src={img.src}
                alt={img.alt}
                width={140}
                height={100}
                class="producto__thumb-img"
                format="webp"
                quality={75}
              />
            </button>
          ))}
        </div>
      </div>

      <!-- Texto + botones -->
      <div class="producto__content">
        <div class="producto__spec-block">
          <div class="producto__spec-top">
            <span class="producto__spec-kicker">Solución técnica</span>
            <h3 class="producto__spec-title">
              Una cubierta más eficiente desde la instalación hasta la operación.
            </h3>
          </div>

          <p class="producto__desc">
            Este sistema de panel para techo ayuda a reducir la ganancia
            térmica, aporta una mejor barrera frente al clima y simplifica el
            montaje al llegar como componente prefabricado. Por eso es una
            opción práctica para arquitectos, ingenieros civiles y propietarios
            que buscan rapidez de ejecución, menor complejidad en obra y una
            cubierta con mejor desempeño integral.
          </p>

          <div class="producto__actions">
            <a href="/contacto/" class="btn-primary producto__btn">
              Solicitar cotización
            </a>
            <a href="#aplicaciones" class="btn-ghost producto__btn">
              Ver aplicaciones
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- FILA INFERIOR: data-grid + lista, ancho completo -->
    <div class="producto__specs">
      <div class="producto__data-grid">
        {datos.map(({ icon: Icon, label, value }) => (
          <div class="producto__data-card">
            <div class="producto__data-copy">
              <Icon class="producto__data-icon" size={18} stroke-width={1.8} />
              <span>{label}</span>
              <strong>{value}</strong>
            </div>
          </div>
        ))}
      </div>

      <ul class="producto__lista">
        {ventajas.map((ventaja) => (
          <li class="producto__item">
            <span class="producto__icon-wrap">
              <Check class="producto__check" size={16} stroke-width={2.4} />
            </span>
            <span>{ventaja}</span>
          </li>
        ))}
      </ul>
    </div>

  </div>
</section>

<style>
  .producto {
    background: var(--color-surface);
  }

  .producto__container {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  /* ── Header ── */
  .producto__header {
    max-width: 880px;
  }

  .producto__title {
    margin-bottom: 1.25rem;
    max-width: 920px;
  }

  .producto__intro {
    max-width: 760px;
  }

  /* ── FILA SUPERIOR ── */
  .producto__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.02fr);
    gap: 2.5rem;
    align-items: start;
  }

  /* ── Galería ── */
  .producto__media {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .producto__image-wrap {
    position: relative;
    overflow: hidden;
    background: #f3f1ec;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-soft);
  }

  .producto__image-wrap::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(14,16,18,0.02), rgba(14,16,18,0.12));
    pointer-events: none;
    z-index: 1;
  }

  .producto__img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
    transition: opacity 0.25s ease;
  }

  .producto__img.is-loading {
    opacity: 0.6;
  }

  .producto__thumbs {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0.5rem;
  }

  .producto__thumb-btn {
    padding: 0;
    border: 2px solid transparent;
    background: #f3f1ec;
    cursor: pointer;
    overflow: hidden;
    transition: border-color 0.2s ease;
  }

  .producto__thumb-btn:hover {
    border-color: rgba(212, 80, 10, 0.5);
  }

  .producto__thumb-btn.active {
    border-color: var(--color-accent);
  }

  .producto__thumb-img {
    width: 100%;
    height: 70px;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .producto__thumb-btn:hover .producto__thumb-img {
    transform: scale(1.05);
  }

  .producto__floating-card {
    position: absolute;
    left: 1.25rem;
    bottom: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 1rem 1.1rem;
    background: rgba(14, 16, 18, 0.94);
    border-left: 3px solid var(--color-accent);
    box-shadow: 0 18px 34px rgba(14, 16, 18, 0.18);
    z-index: 2;
  }

  .producto__floating-label {
    font-family: var(--font-heading);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .producto__floating-value {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--color-white);
    line-height: 1;
  }

  /* ── Contenido derecho ── */
  .producto__content {
    display: flex;
    height: 100%;
  }

  .producto__spec-block {
    width: 100%;
    padding: 2rem;
    border: 1px solid var(--color-border);
    background: linear-gradient(180deg, #ffffff 0%, #faf8f3 100%);
  }

  .producto__spec-top {
    margin-bottom: 1.25rem;
  }

  .producto__spec-kicker {
    display: inline-flex;
    margin-bottom: 0.8rem;
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .producto__spec-title {
    font-family: var(--font-heading);
    font-size: clamp(1.7rem, 3vw, 2.5rem);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .producto__desc {
    margin-bottom: 2rem;
    color: var(--color-text-soft);
    line-height: 1.8;
    font-size: 1rem;
  }

  .producto__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .producto__btn {
    width: auto;
  }

  /* ── FILA INFERIOR: specs ancho completo ── */
  .producto__specs {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 2rem;
    border: 1px solid var(--color-border);
    background: linear-gradient(180deg, #ffffff 0%, #faf8f3 100%);
  }

  .producto__data-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0.75rem;
  }

  .producto__data-card {
    background: var(--color-bg);
    padding: 1rem;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .producto__data-icon {
    color: var(--color-accent);
    flex-shrink: 0;
    margin-bottom: 0.25rem;
  }

  .producto__data-copy {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    align-items: center;
    text-align: center;
  }

  .producto__data-copy span {
    font-size: 0.62rem;
    line-height: 1.4;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-family: var(--font-heading);
    font-weight: 700;
  }

  .producto__data-copy strong {
    font-size: 0.82rem;
    line-height: 1.35;
    color: var(--color-primary);
    font-weight: 700;
  }

  /* Lista 3 columnas aprovechando el ancho completo */
  .producto__lista {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.9rem 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .producto__item {
    display: flex;
    align-items: flex-start;
    gap: 0.8rem;
    color: var(--color-text);
    font-size: 0.96rem;
    line-height: 1.6;
  }

  .producto__icon-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.35rem;
    height: 1.35rem;
    margin-top: 0.15rem;
    flex-shrink: 0;
    background: rgba(212, 80, 10, 0.1);
  }

  .producto__check {
    color: var(--color-accent);
  }

  /* ── Responsive ── */
  @media (max-width: 1100px) {
    .producto__grid {
      grid-template-columns: 1fr;
    }

    .producto__data-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .producto__lista {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 768px) {
    .producto__container {
      gap: 1.5rem;
    }

    .producto__spec-block,
    .producto__specs {
      padding: 1.25rem;
    }

    .producto__data-grid {
      grid-template-columns: 1fr 1fr;
    }

    .producto__lista {
      grid-template-columns: 1fr;
    }

    .producto__actions {
      flex-direction: column;
      align-items: stretch;
    }

    .producto__btn {
      width: 100%;
    }

    .producto__floating-card {
      left: 1rem;
      bottom: 1rem;
    }

    .producto__thumb-img {
      height: 54px;
    }
  }

  @media (max-width: 560px) {
    .producto__data-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const thumbs = document.querySelectorAll<HTMLButtonElement>(".producto__thumb-btn");
    const mainImg = document.getElementById("galeria-main") as HTMLImageElement;

    if (!mainImg) return;

    thumbs.forEach((btn) => {
      btn.addEventListener("click", () => {
        thumbs.forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");

        mainImg.classList.add("is-loading");
        mainImg.src = btn.dataset.src!;
        mainImg.alt = btn.dataset.alt!;

        mainImg.onload = () => mainImg.classList.remove("is-loading");
      });
    });
  });
</script>