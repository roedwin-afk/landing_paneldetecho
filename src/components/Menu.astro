---
const base = import.meta.env.BASE_URL;
---

<a href={`${base}#soluciones`}>Soluciones</a>
<a href={`${base}#aplicaciones`}>Aplicaciones</a>
<a href={`${base}blog/`}>Blog</a>
<a href={`${base}contacto/`}>Cotizar</a>

<style>
  a {
    color: rgba(255,255,255,0.85);
    font-weight: 500;
    font-size: 0.95rem;
    transition: color 0.2s;
  }

  a:hover {
    color: var(--color-accent);
  }

  a:last-child {
    background-color: var(--color-accent);
    color: var(--color-white);
    padding: 0.5rem 1.25rem;
    border-radius: 4px;
    font-weight: 700;
  }

  a:last-child:hover {
    opacity: 0.9;
    color: var(--color-white);
  }
</style>