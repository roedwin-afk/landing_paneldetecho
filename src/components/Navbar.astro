---
import Menu from "./Menu.astro";
import { Image } from "astro:assets";
import logo from "../assets/logo.svg";

const base = import.meta.env.BASE_URL;
---

<nav class="navbar">
  <div class="navbar__inner container">
    <a href={`${base}`} class="menu__link" class="navbar__brand" aria-label="Ir al inicio">
      <Image
        src={logo}
        alt="Panel sándwich para techo industrial"
        width={200}
        height={50}
        class="navbar__logo-img"
        format="webp"
        quality={85}
        loading="eager"
      />
    </a>

    <button
      class="navbar__toggle"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="navbar-menu"
    >
      <span class="line"></span>
      <span class="line"></span>
      <span class="line"></span>
    </button>

    <div id="navbar-menu" class="navbar__menu">
      <Menu />
    </div>
  </div>
</nav>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 1000;
    background: rgba(14, 16, 18, 0.96);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    width: 100%;
  }

  .navbar__inner {
    min-height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .navbar__logo-img {
    display: block;
    height: 2.5rem;
    width: auto;
    filter: brightness(0) invert(1);
  }

  /* --- Estilos del Botón Hamburguesa --- */
  .navbar__toggle {
    display: none; /* Oculto en desktop */
    flex-direction: column;
    justify-content: space-between;
    width: 30px;
    height: 21px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 1001;
  }

  .navbar__toggle .line {
    width: 100%;
    height: 3px;
    background-color: white;
    transition: all 0.3s ease-in-out;
    border-radius: 2px;
  }

  /* --- Layout del Menú (Desktop por defecto) --- */
  .navbar__menu {
    display: flex;
    align-items: center;
  }

  /* --- RESPONSIVE (Móvil) --- */
  @media (max-width: 768px) {
    .navbar__toggle {
      display: flex; /* Mostrar hamburguesa */
    }

    .navbar__menu {
      position: fixed;
      top: 0;
      right: -100%; /* Fuera de la pantalla */
      width: 80%;
      height: 100vh;
      background: #0e1012;
      flex-direction: column;
      padding: 100px 2rem 2rem;
      transition: right 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: -10px 0 30px rgba(0, 0, 0, 0.5);
    }

    /* Clase que activaremos con JS */
    .navbar__menu.is-active {
      right: 0;
    }

    /* Animación de la Hamburguesa a "X" */
    .navbar__toggle[aria-expanded="true"] .line:nth-child(1) {
      transform: translateY(9px) rotate(45deg);
    }
    .navbar__toggle[aria-expanded="true"] .line:nth-child(2) {
      opacity: 0;
    }
    .navbar__toggle[aria-expanded="true"] .line:nth-child(3) {
      transform: translateY(-9px) rotate(-45deg);
    }
  }
</style>

<script>
  // Lógica para abrir/cerrar el menú
  const setupNavbar = () => {
    const toggle = document.querySelector(".navbar__toggle");
    const menu = document.querySelector(".navbar__menu");
    const body = document.body;

    if (toggle && menu) {
      toggle.addEventListener("click", () => {
        const isExpanded = toggle.getAttribute("aria-expanded") === "true";

        toggle.setAttribute("aria-expanded", (!isExpanded).toString());
        menu.classList.toggle("is-active");

        // Evitar que el fondo se mueva cuando el menú está abierto
        body.style.overflow = !isExpanded ? "hidden" : "";
      });
      // Cerrar menú si se hace clic en un enlace
      menu.addEventListener("click", (e) => {
        const target = e.target as HTMLElement; // Forzamos el tipo a HTMLElement

        if (target && target.tagName === "A") {
          toggle.setAttribute("aria-expanded", "false");
          menu.classList.remove("is-active");
          body.style.overflow = "";
        }
      });
    }
  };

  // Correr al cargar la página
  setupNavbar();
</script>
